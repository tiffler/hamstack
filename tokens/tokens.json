{
  "$schema": "https://hamstack.design/schema/tokens.json",
  "name": "hamstack",
  "version": "0.1.0",
  "defaultTheme": "honey-glazed",
  "themes": ["honey-glazed", "prosciutto", "smoked"],
  "semantic": {
    "color": {
      "surface": { "css": "--ham-surface", "role": "Page background" },
      "surface-raised": { "css": "--ham-surface-raised", "role": "Cards, popovers, raised planes" },
      "surface-sunken": { "css": "--ham-surface-sunken", "role": "Inputs, wells, recessed planes" },
      "ink": { "css": "--ham-ink", "role": "Primary text. Never pure black." },
      "ink-soft": { "css": "--ham-ink-soft", "role": "Secondary text" },
      "ink-faint": { "css": "--ham-ink-faint", "role": "Placeholders, captions" },
      "primary": { "css": "--ham-primary", "role": "Primary actions and brand moments. One per view." },
      "accent": { "css": "--ham-accent", "role": "Secondary emphasis. Never competes with primary." },
      "success": { "css": "--ham-success", "role": "Positive feedback" },
      "warning": { "css": "--ham-warning", "role": "Caution feedback" },
      "danger": { "css": "--ham-danger", "role": "Destructive actions and errors" },
      "border": { "css": "--ham-border", "role": "Default hairlines" },
      "ring": { "css": "--ham-ring", "role": "Focus indicator. Always visible." }
    },
    "radius": {
      "sm": { "css": "--ham-radius-sm" },
      "base": { "css": "--ham-radius" },
      "lg": { "css": "--ham-radius-lg" },
      "pill": { "css": "--ham-radius-pill" }
    },
    "space": {
      "scale": "4, 8, then multiples of 8",
      "steps": ["--ham-space-1", "--ham-space-2", "--ham-space-3", "--ham-space-4", "--ham-space-5", "--ham-space-6", "--ham-space-7", "--ham-space-8"]
    },
    "type": {
      "display": { "css": "--ham-font-display", "role": "Headlines only. Use with restraint." },
      "body": { "css": "--ham-font-body", "role": "Everything else" },
      "mono": { "css": "--ham-font-mono", "role": "Code, data" }
    }
  },
  "rules": [
    "Reference semantic tokens only. Raw hex values in components are a violation.",
    "One --ham-primary moment per view. Two primaries is zero primaries.",
    "All text/background pairs must meet WCAG AA (4.5:1).",
    "Respect prefers-reduced-motion via --ham-speed.",
    "Spacing scale: 4, 8, then multiples of 8 only. Never 14, always 16. No orphan pixels."
  ]
}
