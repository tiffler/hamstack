{
  "name": "hamstack",
  "version": "0.1.0",
  "private": true,
  "description": "Hamstack — the design system for the systemless. Open, ownable, honey-glazed.",
  "homepage": "https://hamstack.design",
  "license": "MIT",
  "scripts": {
    "dev": "vite --config preview/vite.config.mjs",
    "build:css": "tailwindcss -c tailwind.config.js -i styles/tailwind.css -o dist/hamstack.css --minify",
    "build": "npm run build:css && vite build --config preview/vite.config.build.mjs"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.0",
    "vite": "^8.1.0",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
